# This .gitignore is appropriate for repositories deployed to GitHub Pages and using
# a Gemfile as specified at https://github.com/github/pages-gem#conventional

# Basic Jekyll gitignores (synchronize to Jekyll.gitignore)
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

baseWebConceitos.ipynb
webConceitosBase.ipynb
node_modules



# Additional Ruby/bundler ignore for when you run: bundle install
/vendor
conceitos

Gemfile.lock

# Arquivos de log do NPM
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Configurações locais do Firebase
.firebase/
firebaserc

# Arquivos do sistema operacional
.DS_Store
Thumbs.db

# Pastas de build/distribuição (se você usa Vite, Webpack ou React)
# dist/ (comentado para permitir deploy no GitHub Pages)
build/
Boas_Praticas.md

